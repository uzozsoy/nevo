# Python caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
.venv/

# PyCharm
.idea/

# Ignore all model/checkpoint files by default
*.pt

# Run outputs: ignore all run directories except main
runs/**
!runs/
!runs/main/
!runs/main/**

# Inside runs/main, keep everything except non-best checkpoints and JSON files
runs/main/**/*.pt
!runs/main/**/*best.pt
runs/main/**/*.json

# Comparison directories
eval/comparison/from_melpe_website/*
!eval/comparison/from_melpe_website/reference/
!eval/comparison/from_melpe_website/reference/**
!eval/comparison/from_melpe_website/main/
!eval/comparison/from_melpe_website/main/**
!eval/comparison/from_melpe_website/melpe/
!eval/comparison/from_melpe_website/melpe/**